{
  "name": "server-swapkit",
  "version": "1.0.0",
  "description": "SwapKit API Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "bun server.ts",
    "dev": "bun --watch server.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "getTokenList": "bun run core/getTokenList.ts",
    "runRealSwap": "bun run core/swap/runRealSwap.ts",
